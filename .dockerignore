# ============================================================
# Docker ignore for Render Godot multiplayer server
# Purpose:
# Keep the server Docker build small and avoid uploading assets,
# exported web builds, caches, editor files, and local junk.
# ============================================================


# -----------------------------
# Git / GitHub
# -----------------------------
.git
.gitignore
.github


# -----------------------------
# Godot editor/import/cache files
# -----------------------------
.godot/
.import/
*.import
*.uid
*.tmp
*.bak
*.log


# -----------------------------
# Exported builds / web game
# The Render multiplayer server does NOT need the browser export.
# The static service serves web/ separately.
# -----------------------------
web/
exports/
export/
build/
builds/
dist/
release/
releases/
bin/


# -----------------------------
# Large client-only art assets
# Keep these ignored unless your Server.tscn directly loads them.
# If the server crashes because of missing assets, remove the
# specific folder/file from this ignore list.
# -----------------------------
assets/audio/
assets/music/
assets/sounds/
assets/sfx/
assets/cutscenes/
assets/backgrounds/
assets/backdrops/
assets/sprites/
assets/textures/
assets/tiles/
assets/tilemaps/
assets/ui/
assets/icons/
assets/vfx/
assets/fx/
assets/particles/


# -----------------------------
# Common media files
# These are usually client-only and unnecessary for the server.
# If Server.tscn references a specific image/audio file, unignore it.
# -----------------------------
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.bmp
*.tga
*.svg
*.mp3
*.wav
*.ogg
*.flac
*.mp4
*.mov
*.avi
*.mkv


# -----------------------------
# Godot exported binary artifacts
# -----------------------------
*.pck
*.wasm
*.zip
*.exe
*.app
*.x86_64
*.arm64
*.apk
*.aab
*.ipa


# -----------------------------
# OS files
# -----------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini


# -----------------------------
# Editor / IDE files
# -----------------------------
.vscode/
.idea/
.cursor/
*.swp
*.swo


# -----------------------------
# Node / frontend junk if present
# -----------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-lock.yaml


# -----------------------------
# Python junk if present
# -----------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/


# -----------------------------
# Local environment files
# -----------------------------
.env
.env.*
!.env.example


# -----------------------------
# Render/local Docker junk
# -----------------------------
Dockerfile.local
docker-compose.yml
docker-compose.*.yml


# ============================================================
# IMPORTANT SERVER FILES TO KEEP
# These override ignore rules above if needed.
# ============================================================

!project.godot
!Server.tscn
!server/
!server/Dockerfile
!scripts/
!scripts/**
!*.gd
!*.tscn
!*.tres
!*.res
!render.yaml